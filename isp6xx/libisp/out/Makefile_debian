SHARED_TARGET := libisp_algo.so
STATIC_TARGET := libisp_algo.a

ifeq ($(CROSS_COMPILER), $(filter $(CROSS_COMPILER), aarch64-none-linux-gnu aarch64-openwrt-linux-gnu))
	LIBISP_ALGO_DIR = glibc_64
else #set glibc_64 default
	LIBISP_ALGO_DIR = glibc_64
endif

install:
	cp ./isp$(ISP_VERSION)_debian/$(LIBISP_ALGO_DIR)/$(TLDIR)/$(STATIC_TARGET) ./$(TLDIR)
	cp ./isp$(ISP_VERSION)_debian/$(LIBISP_ALGO_DIR)/$(TLDIR)/$(SHARED_TARGET) ./$(TLDIR)
	@echo "Setting permissions for ./libAWIspApi_$(ISP_VERSION)/DEBIAN files..."
	@if [ -d "./libAWIspApi_$(ISP_VERSION)/DEBIAN" ]; then \
		find "./libAWIspApi_$(ISP_VERSION)/DEBIAN" -type f -exec chmod 755 {} \;; \
		echo "Permissions set successfully."; \
	else \
		echo "Error: Directory ./libAWIspApi_$(ISP_VERSION)/DEBIAN does not exist!"; \
		exit 1; \
	fi